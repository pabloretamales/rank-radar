---
/**
 * NewsCard.astro
 * Card de una noticia de Pulse IA. Usado en home, category, search.
 *
 * Props:
 *   - item: NewsItem shape (de news-latest.json)
 *   - locale: 'es' | 'en'
 *   - compact: boolean (true = versión sin summary)
 */
const { item, locale = 'es', compact = false } = Astro.props;

const dict = {
  es: {
    viewOriginal: 'Ver fuente original',
    score: 'Score',
    confirmedBy: 'Confirmado por {n} fuentes',
    by: 'Por',
    aiGenerated: 'Resumen generado por IA',
    category: {
      paper: 'Paper',
      tool: 'Herramienta',
      industry: 'Industria',
      model: 'Modelo',
      discussion: 'Discusión',
      startup: 'Startup',
      uncategorized: 'Noticia',
    },
  },
  en: {
    viewOriginal: 'View original source',
    score: 'Score',
    confirmedBy: 'Confirmed by {n} sources',
    by: 'By',
    aiGenerated: 'AI-generated summary',
    category: {
      paper: 'Paper',
      tool: 'Tool',
      industry: 'Industry',
      model: 'Model',
      discussion: 'Discussion',
      startup: 'Startup',
      uncategorized: 'News',
    },
  },
}[locale];

const cat = dict.category[item.category] ?? dict.category.uncategorized;
const confirmedN = item.confirmed_by ?? 1;
const topSources = (item.sources ?? []).slice(0, 2);
const scoreBadge = item.score >= 70 ? 'top' : item.score >= 50 ? 'high' : 'normal';
---

<article class={`news-card news-card--${scoreBadge}`} data-category={item.category}>
  <div class="news-card__head">
    <span class="news-card__category">{cat}</span>
    {item.score >= 70 && <span class="news-card__badge-top">🔥 Top</span>}
    {confirmedN > 1 && (
      <span class="news-card__badge-multi" title={dict.confirmedBy.replace('{n}', String(confirmedN))}>
        ✓ {confirmedN}
      </span>
    )}
    <span class="news-card__score">{dict.score} {item.score}</span>
  </div>

  <h3 class="news-card__title">
    <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
  </h3>

  {!compact && item.summary_es && (
    <p class="news-card__summary">
      {item.summary_es}
      <span class="news-card__ai-tag">{dict.aiGenerated}</span>
    </p>
  )}

  <div class="news-card__meta">
    <span class="news-card__sources">
      {topSources.map((s, i) => (
        <span class="news-card__source">
          {s}
          {i < topSources.length - 1 ? ' · ' : ''}
        </span>
      ))}
    </span>
    {item.submitted_at && (
      <time class="news-card__time" datetime={item.submitted_at}>
        {new Date(item.submitted_at).toLocaleDateString(locale === 'es' ? 'es-CL' : 'en-US', { month: 'short', day: 'numeric' })}
      </time>
    )}
  </div>
</article>

<style>
  .news-card {
    background: var(--bg-card, #fff);
    border: 1px solid var(--border, #e5e5e5);
    border-left: 3px solid var(--border, #e5e5e5);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 10px;
    transition: all 0.15s ease;
  }
  .news-card:hover {
    border-color: var(--accent, #2563eb);
    transform: translateX(2px);
  }
  .news-card--top {
    border-left-color: #f59e0b;
    background: var(--bg-card-top, #fffbeb);
  }
  .news-card--high {
    border-left-color: #3b82f6;
  }
  .news-card__head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .news-card__category {
    color: var(--text-muted, #6b7280);
    font-weight: 600;
  }
  .news-card__badge-top {
    background: #fbbf24;
    color: #422006;
    padding: 1px 6px;
    border-radius: 4px;
    font-weight: 700;
  }
  .news-card__badge-multi {
    background: #10b981;
    color: #022c22;
    padding: 1px 6px;
    border-radius: 4px;
    font-weight: 700;
  }
  .news-card__score {
    margin-left: auto;
    color: var(--text-muted, #6b7280);
    font-variant-numeric: tabular-nums;
  }
  .news-card__title {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 6px;
  }
  .news-card__title a {
    color: inherit;
    text-decoration: none;
  }
  .news-card__title a:hover {
    text-decoration: underline;
  }
  .news-card__summary {
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--text-secondary, #374151);
    margin: 0 0 8px;
  }
  .news-card__ai-tag {
    display: inline-block;
    font-size: 9.5px;
    color: var(--text-muted, #9ca3af);
    border: 1px solid var(--border, #e5e5e5);
    padding: 0 4px;
    border-radius: 3px;
    margin-left: 4px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .news-card__meta {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--text-muted, #9ca3af);
  }
  .news-card__source {
    font-weight: 500;
  }
</style>
