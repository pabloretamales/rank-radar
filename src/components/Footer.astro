---
import type { Locale } from '@/i18n';
import type { Dictionary } from '@/i18n';

interface Props {
  locale: Locale;
  dict: Dictionary;
}
const { dict } = Astro.props;
---

<footer class="border-t mt-12 py-6" style="border-color: var(--border);">
  <div class="container-page flex flex-col gap-2 text-sm" style="color: var(--text-muted);">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-2">
      <span>{dict.footer.madeBy} · {dict.footer.company}</span>
      <span class="text-xs">{dict.footer.builtWith}</span>
    </div>
    <p class="text-xs text-center opacity-80">{dict.footer.credits}</p>
  </div>
</footer>
