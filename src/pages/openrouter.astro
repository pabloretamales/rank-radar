---
import Base from '@/layouts/Base.astro';
import { getDict, detectLocaleFromUrl } from '@/i18n';
import AppCard from '@components/AppCard.astro';
import BarChart from '@components/BarChart.astro';
import openrouterData from '../../public/data/openrouter.json';

const locale = detectLocaleFromUrl(Astro.url);
const dict = getDict(locale);
const r = openrouterData?.rankings ?? {};

// Modelos: 4 pestañas (Hoy / Esta semana / Este mes / Trending)
// Apps: 3 pestañas (Hoy / Una semana / Un mes) — Global Ranking.
const MODEL_TABS = ['today', 'week', 'month', 'trending'];
const APP_TABS   = ['apps_today', 'apps_week', 'apps_month'];

const meta = openrouterData?.apps_meta ?? {};
const appsWindowed = openrouterData?.apps_meta_windowed ?? {};
const rankingsMeta = openrouterData?.rankings_meta ?? {};
const creditLocale = locale === 'es' ? 'es-CL' : 'en-US';

function fmtWindow(start, end) {
  if (!start || !end) return '';
  return `${start} → ${end}`;
}

function formatNum(n) {
  if (n == null) return '—';
  if (n >= 1e12) return (n / 1e12).toFixed(2) + 'T';
  if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';
  if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';
  if (n >= 1e3) return (n / 1e3).toFixed(2) + 'K';
  return String(n);
}

// Charts: uno por ranking, sincronizado con tabs (data-panel={models-${rk}} o apps-${rk})
const chartsByModel = Object.fromEntries(
  MODEL_TABS.map((rk) => [
    rk,
    (r[rk] ?? []).slice(0, 20).map((m) => ({
      label: m.name,
      value: m.total_tokens ?? 0,
      sublabel: m.total_tokens_human,
      href: m.url,
    })),
  ])
);
const chartsByApp = Object.fromEntries(
  APP_TABS.map((rk) => [
    rk,
    (r[rk] ?? []).slice(0, 20).map((a) => ({
      label: a.app_name,
      value: a.total_tokens ?? 0,
      sublabel: a.total_tokens_human,
    })),
  ])
);
---

<Base locale={locale} dict={dict}>
  <header class="mb-6">
    <h1 class="text-3xl font-bold mb-2">{dict.openrouter.title}</h1>
    <p class="text-base max-w-3xl" style="color: var(--text-muted);">{dict.openrouter.subtitle}</p>
  </header>

  <div class="flex flex-wrap gap-2 mb-4 border-b pb-3" style="border-color: var(--border);">
    {MODEL_TABS.map((rk, i) => (
      <button data-section="models" data-ranking={rk} class={`btn-tab ${i === 0 ? 'active' : ''}`}>
        {dict.openrouter.rankings[rk] ?? rk}
      </button>
    ))}
  </div>

  {MODEL_TABS.map((rk, i) => (
    <BarChart
      title={dict.openrouter.chartModelsTitle?.replace('{period}', dict.openrouter.rankings[rk] ?? rk)}
      items={chartsByModel[rk]}
      formatValue={formatNum}
      valueLabel={dict.openrouter.chartUnit}
      panelId={`models-${rk}`}
      class={i === 0 ? '' : 'hidden'}
    />
  ))}

  <!-- ========== SECCIÓN MODELOS ========== -->
  <section class="mb-10">
    <h2 class="text-xl font-bold mb-3">{dict.openrouter.sections.models}</h2>
    <div data-section-panels="models">
      {MODEL_TABS.map((rk, i) => {
        const items = r[rk] ?? [];
        return (
          <div data-panel={`models-${rk}`} class={i === 0 ? '' : 'hidden'}>
            {items.length === 0 ? (
              <p style="color: var(--text-muted);">{dict.openrouter.noResults}</p>
            ) : (
              <>
                {rk === 'trending' && (
                  <p class="text-xs mb-3 opacity-70">{dict.openrouter.trendingNote}</p>
                )}
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-3">
                  {items.map((m) => (
                    <a href={m.url} target="_blank" rel="noopener" class="card block p-4">
                      <div class="flex items-start gap-3">
                        <div class={`rank-badge ${m.rank === 1 ? 'gold' : m.rank === 2 ? 'silver' : m.rank === 3 ? 'bronze' : ''} shrink-0`}>#{m.rank}</div>
                        <div class="flex-1 min-w-0">
                          <div class="flex items-baseline gap-2 flex-wrap">
                            <span class="font-semibold truncate">{m.name}</span>
                            <span class="badge whitespace-nowrap">🪙 {m.total_tokens_human}</span>
                          </div>
                          {rk === 'trending' && m.recent7_human && (
                            <p class="text-xs mt-1" style="color: var(--text-muted);">
                              <span class="text-green-400">{m.recent7_human}</span> <span class="opacity-50">vs</span> <span class="text-red-400">{m.prev7_human}</span>
                            </p>
                          )}
                          {m.context_length != null && (
                            <p class="text-xs mt-1" style="color: var(--text-muted);">
                              📐 {formatNum(m.context_length)} ctx · {m.id}
                            </p>
                          )}
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </>
            )}
          </div>
        );
      })}
    </div>
  </section>

  <div class="flex flex-wrap gap-2 mb-4 border-b pb-3" style="border-color: var(--border);">
    {APP_TABS.map((rk, i) => (
      <button data-section="apps" data-ranking={rk} class={`btn-tab ${i === 0 ? 'active' : ''}`}>
        {dict.openrouter.rankings[rk] ?? rk}
      </button>
    ))}
  </div>

  {APP_TABS.map((rk, i) => (
    <BarChart
      title={dict.openrouter.chartAppsTitle?.replace('{period}', dict.openrouter.rankings[rk] ?? rk)}
      items={chartsByApp[rk]}
      formatValue={formatNum}
      valueLabel={dict.openrouter.chartUnit}
      panelId={`apps-${rk}`}
      class={i === 0 ? '' : 'hidden'}
    />
  ))}

  <!-- ========== SECCIÓN APPS — Global Ranking ========== -->
  <section class="mb-10">
    <h2 class="text-xl font-bold mb-3">{dict.openrouter.sections.apps}</h2>
    <div data-section-panels="apps">
      {APP_TABS.map((rk, i) => {
        const items = r[rk] ?? [];
        const winMeta = appsWindowed[rk.replace('apps_','')] ?? {};
        const winLabel = fmtWindow(winMeta.start_date, winMeta.end_date);
        return (
          <div data-panel={`apps-${rk}`} class={i === 0 ? '' : 'hidden'}>
            <p class="text-xs mb-3 opacity-60">
              {dict.openrouter.windowNote?.replace('{start}', winMeta.start_date ?? '?').replace('{end}', winMeta.end_date ?? '?') ?? winLabel}
            </p>
            {items.length === 0 ? (
              <p style="color: var(--text-muted);">{dict.openrouter.noResults}</p>
            ) : (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                {items.map((app) => <AppCard app={app} dict={dict} compact />)}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </section>

  <aside class="card p-3 mt-8 text-sm" style="background: var(--bg-card); border-left: 3px solid var(--accent);">
    <p class="font-semibold text-xs uppercase tracking-wider mb-1" style="color: var(--text-muted);">
      {dict.openrouter.explainer.credit.openrouter}
    </p>
    <p class="text-sm">
      Source: <a href="https://openrouter.ai/rankings" class="badge ml-1" target="_blank" rel="noopener">OpenRouter</a> (openrouter.ai/rankings), as of <time class="tabular-nums font-semibold">{rankingsMeta.as_of ? new Date(rankingsMeta.as_of).toLocaleString(creditLocale) : 'N/A'}</time>
      <span class="opacity-60 ml-2">· {rankingsMeta.version ?? meta.version ?? 'v1'} · ventana {rankingsMeta.start_date ?? meta.start_date ?? '?'} → {rankingsMeta.end_date ?? meta.end_date ?? '?'}</span>
    </p>
  </aside>
</Base>

<script is:inline>
  function setupTabs(section) {
    const btns = document.querySelectorAll(`[data-section="${section}"][data-ranking]`);
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-ranking');
        btns.forEach((b) => b.classList.toggle('active', b === btn));
        document.querySelectorAll(`[data-panel^="${section}-"]`).forEach((p) => {
          p.classList.toggle('hidden', p.getAttribute('data-panel') !== `${section}-${target}`);
        });
      });
    });
  }
  setupTabs('models');
  setupTabs('apps');
</script>