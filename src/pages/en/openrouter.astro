---
import Base from '@/layouts/Base.astro';
import { getDict } from '@/i18n';
import AppCard from '@components/AppCard.astro';
import ORModelCard from '@components/ORModelCard.astro';
import openrouterData from '../../../public/data/openrouter.json';

const locale = 'en' as const;
const dict = getDict(locale);
const r = openrouterData?.rankings ?? {};
const RANKINGS = ['apps_popular', 'apps_trending', 'by_tokens', 'by_recent', 'models_by_tokens'];
const APP_RANKINGS = ['apps_popular', 'apps_trending', 'by_tokens'];
const MODEL_TOKEN_RANKINGS = ['models_by_tokens'];
const isApp = (rk) => APP_RANKINGS.includes(rk);
const isModelTokens = (rk) => MODEL_TOKEN_RANKINGS.includes(rk);
const meta = openrouterData?.apps_meta ?? {};
---

<Base locale={locale} dict={dict}>
  <header class="mb-6">
    <h1 class="text-3xl font-bold mb-2">{dict.openrouter.title}</h1>
    <p class="text-base max-w-3xl" style="color: var(--text-muted);">{dict.openrouter.subtitle}</p>
    {meta?.start_date && (
      <p class="text-xs mt-2" style="color: var(--text-muted);">
        Apps window: {meta.start_date} → {meta.end_date} · v{meta.version}
      </p>
    )}
  </header>

  <aside class="card p-4 mb-6 text-sm" style="background: var(--bg-card);">
    <h2 class="font-semibold mb-2">💡 {dict.openrouter.explainer.heading}</h2>
    <p class="mb-2" style="color: var(--text-muted);">{dict.openrouter.explainer.models_vs_apps}</p>
    <p style="color: var(--text-muted);">{dict.openrouter.explainer.popular_vs_trending}</p>
    <p class="mt-2" style="color: var(--text-muted);">{dict.openrouter.explainer.recent_note}</p>
    <p class="mt-3 text-xs">
      {dict.openrouter.explainer.official_link}
      <a class="badge ml-1" href="https://openrouter.ai/rankings/models" target="_blank" rel="noopener">openrouter.ai/rankings/models</a>
    </p>
  </aside>

  <div class="flex flex-wrap gap-2 mb-6 border-b pb-3" style="border-color: var(--border);">
    {RANKINGS.map((rk, i) => (
      <button data-ranking={rk} class={`btn-tab ${i === 0 ? 'active' : ''}`}>
        {dict.openrouter.rankings[rk] ?? rk}
      </button>
    ))}
  </div>

  <div id="or-panels">
    {RANKINGS.map((rk, i) => {
      const items = r[rk] ?? [];
      return (
        <div data-panel={rk} class={i === 0 ? '' : 'hidden'}>
          {items.length === 0 ? (
            <p style="color: var(--text-muted);">{dict.openrouter.noResults}</p>
          ) : isApp(rk) ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-3">
              {items.map((app) => <AppCard app={app} dict={dict} />)}
            </div>
          ) : isModelTokens(rk) ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-3">
              {items.map((m) => (
                <a href={m.url} target="_blank" rel="noopener" class="card block p-4">
                  <div class="flex items-start gap-3">
                    <div class={`rank-badge ${m.rank === 1 ? 'gold' : m.rank === 2 ? 'silver' : m.rank === 3 ? 'bronze' : ''} shrink-0`}>#{m.rank}</div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-baseline gap-2 flex-wrap">
                        <span class="font-semibold truncate">{m.name}</span>
                        <span class="badge whitespace-nowrap">🪙 {m.total_tokens_human}</span>
                      </div>
                      {m.context_length != null && (
                        <p class="text-xs mt-1" style="color: var(--text-muted);">📐 {(m.context_length >= 1e6 ? (m.context_length/1e6).toFixed(1) + 'M' : m.context_length >= 1e3 ? (m.context_length/1e3).toFixed(0) + 'K' : m.context_length)} ctx · {m.id}</p>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-3">
              {items.map((model) => <ORModelCard model={model} ranking={rk} dict={dict} />)}
            </div>
          )}
        </div>
      );
    })}
  </div>
</Base>

<script is:inline>
  document.querySelectorAll('[data-ranking]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-ranking');
      document.querySelectorAll('[data-ranking]').forEach((b) => b.classList.toggle('active', b === btn));
      document.querySelectorAll('[data-panel]').forEach((p) => {
        p.classList.toggle('hidden', p.getAttribute('data-panel') !== target);
      });
    });
  });
</script>
