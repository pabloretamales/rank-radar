---
/**
 * /about — Pulse IA: página de news extendida
 *
 * Same data as home, but more cards (las items disponibles del snapshot).
 * Sin metodología / sin academic-speak — solo el listado de noticias.
 */
import Base from '@/layouts/Base.astro';
import { getDict, detectLocaleFromUrl } from '@/i18n';
import newsData from '../../public/data/news-latest.json';
import NewsCard from '@components/news/NewsCard.astro';

const locale = detectLocaleFromUrl(Astro.url);
const dict = getDict(locale);

// Tomamos todos los items del snapshot del día
const allNews = newsData?.items ?? [];

const pageTitle = locale === 'es' ? 'Todas las noticias de hoy' : 'All today\'s news';
const subtitle = locale === 'es'
  ? `${allNews.length} noticias curadas, resumidas por IA en español.`
  : `${allNews.length} curated news items, AI-summarized in Spanish.`;
---

<Base locale={locale} dict={dict} title={pageTitle}>
  <article class="news-feed">
    <header class="mb-6">
      <h1 class="text-2xl font-bold mb-1">{pageTitle}</h1>
      <p class="text-sm" style="color: var(--text-muted);">{subtitle}</p>
    </header>
    {allNews.length === 0 ? (
      <p class="text-center py-8" style="color: var(--text-muted);">
        {locale === 'es' ? 'No hay noticias disponibles para hoy.' : 'No news available for today.'}
      </p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
        {allNews.map((it) => <NewsCard item={it} locale={locale} />)}
      </div>
    )}
  </article>
</Base>

<style>
  .news-feed { max-width: 1200px; margin: 0 auto; padding: 1rem; }
</style>
