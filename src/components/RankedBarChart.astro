---
/**
 * RankedBarChart — top-N horizontal bar chart with rank, label, magnitude bar, and value.
 * Plain CSS, no JS, no charting libs. The bar length encodes the value relative to the max.
 */
interface Item {
  rank: number;
  name: string;
  value: number;
  valueHuman: string;
  url?: string;
}
interface Props {
  items: Item[];
  topN?: number;
  rankLabel?: string;
  color?: string; // CSS color for the bar fill
  trackColor?: string; // CSS color for the empty track
  numberUnit?: string; // e.g. "B" or "T" — currently unused, just info
}
const { items, topN = 10, rankLabel = '#', color = 'var(--accent, #7c3aed)', trackColor = 'var(--bg-muted, #e5e7eb)' } = Astro.props;
const sliced = (items ?? []).slice(0, topN);
const max = Math.max(1, ...sliced.map((it) => Number(it.value) || 0));
---

<div class="ranked-bar-chart">
  {sliced.length === 0 ? (
    <p class="text-sm" style="color: var(--text-muted);">—</p>
  ) : (
    <ol class="space-y-1.5">
      {sliced.map((it) => {
        const v = Number(it.value) || 0;
        const pct = Math.max(2, Math.round((v / max) * 100)); // min 2% so 0 isn't invisible
        const Wrapper = it.url ? 'a' : 'div';
        const wrapperProps = it.url
          ? { href: it.url, target: '_blank', rel: 'noopener', class: 'flex items-center gap-3 group hover:opacity-90 transition' }
          : { class: 'flex items-center gap-3 group' };
        return (
          <li class="flex items-center gap-3 text-sm">
            <span class="text-xs tabular-nums w-5 text-right shrink-0" style="color: var(--text-muted);">{rankLabel}{it.rank}</span>
            <Wrapper {...wrapperProps}>
              <span class="w-28 sm:w-32 truncate shrink-0" style="color: var(--text);" title={it.name}>{it.name}</span>
              <span class="flex-1 relative h-2.5 rounded-full overflow-hidden" style={`background:${trackColor};`}>
                <span
                  class="absolute inset-y-0 left-0 rounded-full transition-all"
                  style={`width:${pct}%;background:${color};`}
                />
              </span>
              <span class="tabular-nums text-xs w-16 text-right shrink-0" style="color: var(--text-muted);">{it.valueHuman}</span>
            </Wrapper>
          </li>
        );
      })}
    </ol>
  )}
</div>

<style>
  .ranked-bar-chart ol { list-style: none; padding: 0; margin: 0; }
  .ranked-bar-chart li { line-height: 1.2; }
</style>