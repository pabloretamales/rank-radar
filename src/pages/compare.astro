---
import Base from '@/layouts/Base.astro';
import { getDict, detectLocaleFromUrl } from '@/i18n';
import mergedData from '../../public/data/models-merged.json';

const locale = detectLocaleFromUrl(Astro.url);
const dict = getDict(locale);

// Sólo modelos que tienen intelligence (534/543), ordenados alfabéticamente para el datalist
const models = (mergedData?.models ?? [])
  .filter((m) => m.intelligence != null)
  .sort((a, b) => a.name.localeCompare(b.name))
  .map((m) => ({
    name: m.name,
    slug: m.slug,
    creator: m.creator ?? '',
  }));

// Pre-serializar para el cliente
const modelsJson = JSON.stringify(models);
---

<Base locale={locale} dict={dict}>
  <header class="mb-6">
    <h1 class="text-3xl font-bold mb-2">{dict.compare.title}</h1>
    <p class="text-base max-w-3xl" style="color: var(--text-muted);">{dict.compare.subtitle}</p>
  </header>

  <div class="flex flex-col sm:flex-row gap-2 mb-6">
    <input id="m1" list="models-dl" placeholder={dict.compare.placeholder1} class="flex-1 px-3 py-2 rounded-md border" style="background: var(--bg-card); border-color: var(--border); color: var(--text);" />
    <input id="m2" list="models-dl" placeholder={dict.compare.placeholder2} class="flex-1 px-3 py-2 rounded-md border" style="background: var(--bg-card); border-color: var(--border); color: var(--text);" />
    <input id="m3" list="models-dl" placeholder={dict.compare.placeholder3} class="flex-1 px-3 py-2 rounded-md border" style="background: var(--bg-card); border-color: var(--border); color: var(--text);" />
  </div>

  <datalist id="models-dl"></datalist>

  <div id="status" class="mb-4 text-sm" style="color: var(--text-muted);"></div>

  <div class="flex gap-2 mb-6">
    <button id="btn-compare" class="px-4 py-2 rounded-md font-medium" style="background: var(--accent); color: white;">{dict.compare.btnCompare}</button>
    <button id="btn-clear" class="px-4 py-2 rounded-md border" style="border-color: var(--border); color: var(--text);">{dict.compare.btnClear}</button>
  </div>

  <div id="result"></div>

  <script type="application/json" id="models-data" set:html={modelsJson}></script>
  <script is:inline>
    (function() {
      const data = JSON.parse(document.getElementById('models-data').textContent);
      const dl = document.getElementById('models-dl');
      for (const m of data) {
        const opt = document.createElement('option');
        opt.value = m.name;
        opt.label = m.slug ? m.slug + ' (' + m.creator + ')' : m.creator;
        dl.appendChild(opt);
      }

      function findModel(query) {
        if (!query) return null;
        const q = query.trim().toLowerCase();
        if (!q) return null;
        const exact = data.find(m => m.name.toLowerCase() === q || m.slug === q);
        if (exact) return exact;
        return data.find(m => m.name.toLowerCase().includes(q) || m.slug.includes(q)) || null;
      }

      function clear() {
        document.getElementById('m1').value = '';
        document.getElementById('m2').value = '';
        document.getElementById('m3').value = '';
        document.getElementById('result').innerHTML = '';
        document.getElementById('status').textContent = '';
      }

      async function loadModel(slug) {
        const res = await fetch('/data/models-merged.json');
        const all = await res.json();
        return all.models.find(m => m.slug === slug) || null;
      }

      async function doCompare() {
        const inputs = [
          document.getElementById('m1').value,
          document.getElementById('m2').value,
          document.getElementById('m3').value,
        ].filter(Boolean);
        if (inputs.length === 0) {
          document.getElementById('result').innerHTML = '';
          document.getElementById('status').textContent = '';
          return;
        }
        const queries = inputs.map(findModel);
        const missing = queries.map((q, i) => q ? null : inputs[i]).filter(Boolean);
        if (missing.length) {
          document.getElementById('status').textContent = 'No encontrado: ' + missing.join(', ');
          return;
        }
        document.getElementById('status').textContent = '';
        const models = queries.map(q => q.slug);
        renderTable(models);
      }

      function fmtPrice(p) {
        if (p == null) return '—';
        if (p < 0.01) return '$' + p.toExponential(1);
        return '$' + p.toFixed(2);
      }

      function fmtInt(n) {
        if (n == null) return '—';
        if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
        if (n >= 1e3) return (n / 1e3).toFixed(0) + 'K';
        return n.toLocaleString();
      }

      function fmtFloat(v, digits) {
        if (v == null) return '—';
        return v.toFixed(digits ?? 1);
      }

      function badgesFor(mod) {
        const out = [];
        if (mod.intelligence != null) out.push(`<span class="badge">🧠 ${fmtFloat(mod.intelligence)}</span>`);
        if (mod.coding != null) out.push(`<span class="badge">💻 ${fmtFloat(mod.coding)}</span>`);
        if (mod.agentic != null) out.push(`<span class="badge">🤖 ${fmtFloat(mod.agentic)}</span>`);
        return out.join(' ');
      }

      async function renderTable(modelSlugs) {
        const res = await fetch('/data/models-merged.json');
        const data = await res.json();
        const rows = [];
        for (const slug of modelSlugs) {
          const m = data.models.find(x => x.slug === slug);
          if (m) rows.push(m);
        }

        const labels = ['intelligence', 'coding', 'agentic', 'creator', 'release', 'tokens_per_sec', 'ttft', 'price_input', 'price_output', 'context', 'modalities', 'or_url'];
        const I18N = {
          intelligence: 'Intelligence Index',
          coding: 'Coding Index',
          agentic: 'Agentic Index',
          creator: 'Creador',
          release: 'Lanzamiento',
          tokens_per_sec: 'Velocidad (tok/s)',
          ttft: 'TTFT (s)',
          price_input: 'Precio input ($/M)',
          price_output: 'Precio output ($/M)',
          context: 'Context window',
          modalities: 'Modalidades',
          or_url: 'OR link',
        };

        const cell = (mod, key) => {
          switch (key) {
            case 'intelligence':
            case 'coding':
            case 'agentic':
              return mod[key] == null ? '—' : mod[key].toFixed(1);
            case 'creator':
              return mod.creator ?? '—';
            case 'release':
              return mod.release_date ?? '—';
            case 'tokens_per_sec':
              return mod.tokens_per_sec != null ? mod.tokens_per_sec.toFixed(0) : '—';
            case 'ttft':
              return mod.ttft_seconds != null ? mod.ttft_seconds.toFixed(2) : '—';
            case 'price_input':
              return fmtPrice(mod.price_input);
            case 'price_output':
              return fmtPrice(mod.price_output);
            case 'context':
              return mod.or ? fmtInt(mod.or.context_length) : '—';
            case 'modalities':
              return mod.or?.modalities?.length
                ? mod.or.modalities.map(m => `<span class="px-1" title="${m}">${({text:'📝',image:'🖼',audio:'🎵',video:'🎬',file:'📎'}[m.replace('→','')] ?? '🔹')}</span>`).join('')
                : '—';
            case 'or_url':
              return mod.or?.url ? `<a href="${mod.or.url}" target="_blank" class="badge">→</a>` : '—';
          }
          return '—';
        };

        let html = '<div class="overflow-x-auto"><table class="w-full"><thead><tr>';
        html += '<th class="text-left py-2 pr-3" style="color: var(--text-muted);">Métrica</th>';
        for (const m of rows) {
          html += '<th class="text-left py-3 pl-3">' +
            `<div class="font-semibold truncate" title="${m.name}">${m.name}</div>` +
            `<div class="text-xs font-normal mt-1">${badgesFor(m)}</div>` +
            '</th>';
        }
        html += '</tr></thead><tbody>';

        for (const key of labels) {
          html += '<tr class="border-t" style="border-color: var(--border);">';
          html += `<td class="py-2 pr-3" style="color: var(--text-muted);">${I18N[key]}</td>`;
          for (const m of rows) {
            html += `<td class="py-2 pl-3">${cell(m, key)}</td>`;
          }
          html += '</tr>';
        }

        html += '</tbody></table></div>';
        document.getElementById('result').innerHTML = html;
      }

      document.getElementById('btn-compare').addEventListener('click', doCompare);
      document.getElementById('btn-clear').addEventListener('click', clear);

      // Inicial: muestra el mensaje vacío
      document.getElementById('result').innerHTML =
        '<p style="color: var(--text-muted);">Elegí hasta 3 modelos arriba y hacé click en Comparar.</p>';
    })();
  </script>
</Base>
