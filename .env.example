# =============================================================================
# RankRadar — Variables de entorno (plantilla, NO contiene secretos reales)
# Copiá este archivo a `.env` y completá los valores. `.env` está gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# ExploreYC — Sección nueva (5 YC AI projects / día)
# -----------------------------------------------------------------------------
# Free tier: 5 requests/day rolling 24h. Conseguir en https://www.exploreyc.com/dashboard
EYC_API_KEY=eyc_live_REEMPLAZAR_CON_TU_KEY

# -----------------------------------------------------------------------------
# Pipeline original — solo necesarios si corrés `npm run pipeline` completo.
# Si solo corrés `npm run fetch:exploreyc`, no hacen falta.
# -----------------------------------------------------------------------------

# GitHub Trending (5000 req/h autenticado). Scope: public_repo.
GITHUB_TOKEN=ghp_REEMPLAZAR_CON_TU_TOKEN

# Artificial Analysis (free tier: 543 modelos y benchmarks principales).
ARTIFICIAL_ANALYSIS_API_KEY=aa_REEMPLAZAR_CON_TU_KEY

# OpenRouter — sirve cualquier key con 0 crédito.
# Se usa para /api/v1/datasets/app-rankings (no consume tokens de inferencia).
OPENROUTER_API_KEY=sk-or-REEMPLAZAR_CON_TU_KEY
