---
import Base from '@/layouts/Base.astro';
import { getDict, detectLocaleFromUrl } from '@/i18n';
import RepoCard from '@components/RepoCard.astro';
import BarChart from '@components/BarChart.astro';
import githubData from '../../public/data/github-windows.json';

const locale = detectLocaleFromUrl(Astro.url);
const dict = getDict(locale);
const ALL_WINDOWS = ['1d', '7d', '30d', '90d', 'all'];
// Filtrar ventanas sin items (si 1d no trajo nada, no se muestra la pestaña)
const ALL = githubData?.windows ?? [];
const windows = ALL.filter((w) => (w.items?.length ?? 0) > 0);
const visibleLabels = windows.map((w) => w.label);
const totalItems = windows.reduce((s, w) => s + (w.items?.length ?? 0), 0);

// Chart: top 20 repos por stars en la ventana principal (la que tiene tabs por default)
const defaultWindow = windows.find((w) => w.label === '7d') ?? windows[0];
const chartItems = (defaultWindow?.items ?? []).slice(0, 20).map((r) => ({
  label: r.full_name,
  value: r.stargazers_count ?? 0,
  sublabel: `${(r.stargazers_count ?? 0).toLocaleString()} ⭐ · ${r.language ?? '—'}`,
  href: r.html_url,
}));
---

<Base locale={locale} dict={dict}>
  <header class="mb-8">
    <h1 class="text-3xl font-bold mb-2">{dict.github.title}</h1>
    <p class="text-base max-w-3xl" style="color: var(--text-muted);">{dict.github.subtitle}</p>
    <p class="text-xs mt-3 italic" style="color: var(--text-muted);">ℹ️ {dict.github.caveat}</p>
    <p class="text-xs mt-1" style="color: var(--text-muted);">{totalItems} repos · {windows.length} ventanas</p>
  </header>

  <BarChart
    title={dict.github.chartTitle?.replace('{window}', defaultWindow?.label ?? '')}
    items={chartItems}
    valueLabel={dict.github.chartUnit}
  />

  <div class="flex flex-wrap gap-2 mb-6 border-b pb-3" style="border-color: var(--border);">
    {windows.length === 0 ? (
      <p class="text-sm" style="color: var(--text-muted);">{dict.github.noResults}</p>
    ) : windows.map((w, i) => (
      <button data-window={w.label} class={`btn-tab ${i === 0 ? 'active' : ''}`}>
        {dict.github.windows[w.label]}
        <span class="ml-1 opacity-50 text-xs">({w.items.length})</span>
      </button>
    ))}
  </div>

  <div id="github-panels">
    {windows.length === 0 ? null : windows.map((w, i) => (
      <div data-panel={w.label} class={i === 0 ? '' : 'hidden'}>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-3">
          {w.items.map((repo) => <RepoCard repo={repo} dict={dict} />)}
        </div>
      </div>
    ))}
  </div>
</Base>

<script is:inline>
  document.querySelectorAll('[data-window]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-window');
      document.querySelectorAll('[data-window]').forEach((b) => b.classList.toggle('active', b === btn));
      document.querySelectorAll('[data-panel]').forEach((p) => {
        p.classList.toggle('hidden', p.getAttribute('data-panel') !== target);
      });
    });
  });
</script>
